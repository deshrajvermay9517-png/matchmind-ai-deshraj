# Server Configuration
PORT=5000

# IBM watsonx.ai Credentials
# Generate an API key from IBM Cloud console: https://cloud.ibm.com/iam/apikeys
WATSONX_API_KEY=your_ibm_cloud_api_key

# Create a Project in watsonx.ai and get the project ID from its settings
WATSONX_PROJECT_ID=your_watsonx_project_id

# IBM watsonx.ai service endpoint URL
# Common endpoints:
# US South (Dallas): https://us-south.ml.cloud.ibm.com
# Europe United Kingdom (London): https://eu-gb.ml.cloud.ibm.com
# Europe Germany (Frankfurt): https://eu-de.ml.cloud.ibm.com
# Tokyo: https://jp-tok.ml.cloud.ibm.com
WATSONX_URL=https://us-south.ml.cloud.ibm.com

# Model selection (e.g. ibm/granite-13b-chat-v2 or ibm/granite-3-8b-instruct)
WATSONX_MODEL_ID=ibm/granite-13b-chat-v2
